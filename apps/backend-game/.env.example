# --- APP SETTINGS ---
# Use 3000 for backend-api, and maybe 3001 for backend-game to avoid conflicts
PORT=3000 

# --- SUPABASE CONFIGURATION ---
# Found in Supabase Dashboard -> Project Settings -> API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_KEY=your_supabase_anon_key_here

# Default local Redis settings if using Docker
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD= # Leave blank if local, fill in if using Upstash/Cloud Redis